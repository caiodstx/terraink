APP_PORT=7200
VITE_UPDATES_URL=/updates.json
VITE_CONTACT_EMAIL=hello@example.com
# Raw markdown URLs for the in-app legal modal (imprint + privacy).
VITE_LEGAL_NOTICE_URL=https://raw.githubusercontent.com/USER/META-REPO/main/imprint.md
VITE_PRIVACY_URL=https://raw.githubusercontent.com/USER/META-REPO/main/privacy.md

# Google Search Console verification token
VITE_GOOGLE_SITE_VERIFICATION=

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
VITE_GA_MEASUREMENT_ID=

# Canvas credits URL (shown bottom-left on the poster when Show Credits is enabled)
VITE_APP_CREDIT_URL=mapagrama.com
