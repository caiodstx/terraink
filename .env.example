APP_PORT=7200

# mapagrama-api base URL. Production uses "/api" (nginx reverse-proxy
# strips the prefix) — set this only for local dev against a separate
# `bun run dev` instance of mapagrama-api.
VITE_API_BASE_URL=http://localhost:8787

VITE_UPDATES_URL=/updates.json
VITE_CONTACT_EMAIL=hello@example.com
# Raw markdown URLs for the in-app legal modal. Hosted on the R2 public
# bucket (mapagrama-api) under the "legal/" prefix.
VITE_LEGAL_NOTICE_URL=https://designs.mapagrama.com/legal/imprint.md
VITE_PRIVACY_URL=https://designs.mapagrama.com/legal/privacy.md
VITE_TERMS_URL=https://designs.mapagrama.com/legal/terms.md
VITE_WITHDRAWAL_URL=https://designs.mapagrama.com/legal/withdrawal.md

# Google Search Console verification token
VITE_GOOGLE_SITE_VERIFICATION=

# Canvas credits URL (shown bottom-left on the poster when Show Credits is enabled)
VITE_APP_CREDIT_URL=mapagrama.com
